{
  "theme": "vs-dark-modern",
  "icons": "nerd",
  "separator": " │ ",
  "lines": [
    ["model", "effort", "cwd", "git", "env"],
    ["context", "limits", "tokens", "cache"]
  ],
  "segments": {
    "cwd": {"max_length": 40},
    "git": {"ahead_glyph": "↑", "behind_glyph": "↓", "show_worktree": true},
    "cost": {"show_session": true, "show_day": true, "show_month": true},
    "cost_day_forecast": {"window": 7, "show_arrow": true, "show_avg": true},
    "cost_month_forecast": {"window": 7, "show_arrow": true, "show_so_far": false, "decimals": 0},
    "context": {"style": "bar", "bar_width": 10},
    "limits": {"style": "bar", "bar_width": 10, "show_text": true},
    "tokens": {
      "show_input": true,
      "show_output": true,
      "show_cache_creation": true,
      "show_icon": false,
      "output_warn_threshold": 6000
    },
    "tokens-session": {"show_input": true, "show_output": true},
    "cache": {
      "show_hit_ratio": true,
      "show_ttl": true,
      "show_at_risk": true,
      "show_icon": true,
      "hit_warn_below": 70,
      "hit_crit_below": 30,
      "ttl_warn_seconds": 30,
      "at_risk_min": 0.01
    }
  },
  "colors": {
    "model": "accent",
    "cwd": "primary",
    "git.branch": "secondary",
    "git.added": "success",
    "git.modified": "warning",
    "git.deleted": "error",
    "git.renamed": "accent",
    "git.untracked": "muted",
    "git.no_upstream": "muted",
    "git.op": "error",
    "git.worktree": "accent",
    "cost.session": "primary",
    "cost.day": "muted",
    "cost.month": "muted",
    "cost_day_forecast.avg": "muted",
    "cost_day_forecast.under": "success",
    "cost_day_forecast.ok": "warning",
    "cost_day_forecast.warn": "#D97757",
    "cost_day_forecast.over": "error",
    "cost_month_forecast.forecast": "muted",
    "cost_month_forecast.so_far": "muted",
    "cost_month_forecast.under": "success",
    "cost_month_forecast.ok": "warning",
    "cost_month_forecast.warn": "#D97757",
    "cost_month_forecast.over": "error",
    "context.normal": "muted",
    "context.warn": "warning",
    "context.crit": "error",
    "limits.empty": "dim",
    "limits.text": "muted",
    "tokens.icon": "muted",
    "tokens.input": "muted",
    "tokens.output": "muted",
    "tokens.output_high": "warning",
    "tokens.cache_creation": "warning",
    "tokens_session.icon": "muted",
    "tokens_session.input": "muted",
    "tokens_session.output": "muted",
    "cache.hit_high": "success",
    "cache.hit_low": "warning",
    "cache.hit_crit": "error",
    "cache.ttl": "muted",
    "cache.ttl_warn": "warning",
    "cache.expired": "error",
    "cache.at_risk": "muted",
    "duration": "muted",
    "runtime": "muted",
    "cc_version": "muted",
    "separator": "dim"
  }
}
